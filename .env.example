# ── Contoh konfigurasi environment ──────────────────────────────
# Salin berkas ini menjadi ".env" lalu sesuaikan. Semua opsional.

# Lokasi folder data pelamar (setiap subfolder = 1 pelamar).
# Jika tidak diisi, aplikasi memakai ./data (bila ada isinya) atau folder induk.
# PELAMAR_DIR=./data

# Port server HTTP.
# PORT=3000
